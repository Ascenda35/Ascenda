{
  "name": "Ascenda - DSE Ranking Platform",
  "short_name": "Ascenda",
  "description": "Hong Kong DSE student competitive ranking platform with real-time leaderboards and university admission predictions",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "zh-HK",
  "categories": ["education", "productivity", "utilities"],
  "icons": [
    {
      "src": "data:image/svg+xml;base64,",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "data:image/svg+xml;base64,",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Leaderboard",
      "short_name": "Ranks",
      "description": "View DSE student rankings",
      "url": "/",
      "icons": [
        {
          "src": "data:image/svg+xml;base64,",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Profile",
      "short_name": "Profile",
      "description": "View your profile and upload scores",
      "url": "/profile.html",
      "icons": [
        {
          "src": "data:image/svg+xml;base64,",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "JUPAS Dream Map",
      "short_name": "Dream Map",
      "description": "Explore university programs",
      "url": "/jupas.html",
      "icons": [
        {
          "src": "data:image/svg+xml;base64,",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "data:image/svg+xml;base64,",
      "sizes": "320x568",
      "type": "image/svg+xml",
      "form_factor": "narrow"
    },
    {
      "src": "data:image/svg+xml;base64,",
      "sizes": "1280x720",
      "type": "image/svg+xml",
      "form_factor": "wide"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+ascenda",
      "url": "/?handler=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/grade.html",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png"]
      }
    }
  ],
  "share_target": {
    "action": "/profile.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "scoreImage",
          "accept": ["image/*"]
        }
      ]
    }
  }
}
